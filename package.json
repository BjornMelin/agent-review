{
  "name": "review-agent-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Codex-grade review agent platform",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint --concurrency=1",
    "test": "turbo run test",
    "format": "turbo run format",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "repro-check": "bash scripts/repro-check.sh",
    "dev": "turbo run dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^24.12.3",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
