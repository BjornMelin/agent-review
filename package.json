{
  "name": "review-agent-platform",
  "private": true,
  "description": "Codex-grade review agent platform",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint --concurrency=1",
    "test": "turbo run test",
    "format": "turbo run format",
    "rust:fmt": "cargo fmt --all -- --check",
    "rust:clippy": "cargo clippy --workspace --all-targets --all-features --locked -- -D warnings",
    "rust:test": "cargo test --workspace --all-targets --all-features --locked",
    "rust:check": "pnpm rust:fmt && pnpm rust:clippy && pnpm rust:test",
    "ci:contracts": "bash scripts/check-generated-contracts.sh",
    "ci:security": "bash scripts/security-audit.sh",
    "ci:preview-smoke": "node scripts/preview-smoke.mjs",
    "ci:agent-browser-preview": "bash scripts/agent-browser-preview-smoke.sh",
    "ci:cli-release": "node --test scripts/cli-release-utils.test.mjs scripts/cli-release-metadata.test.mjs && node scripts/package-cli-release.mjs --out-dir release --expected-target linux-x64-gnu --verify",
    "git:benchmark": "pnpm --filter @review-agent/review-git benchmark",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm rust:check",
    "repro-check": "bash scripts/repro-check.sh",
    "release:cli:archive": "node scripts/package-cli-release.mjs",
    "release:cli:verify": "node scripts/verify-cli-release.mjs",
    "dev": "turbo run dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^24.12.3",
    "agent-browser": "0.27.0",
    "tar": "7.5.19",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
