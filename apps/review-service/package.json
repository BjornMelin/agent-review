{
  "name": "@review-agent/review-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "dev": "tsx src/server.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/request": "^10.0.8",
    "@review-agent/review-convex-bridge": "workspace:*",
    "@review-agent/review-core": "workspace:*",
    "@review-agent/review-provider-registry": "workspace:*",
    "@review-agent/review-reporters": "workspace:*",
    "@review-agent/review-types": "workspace:*",
    "@review-agent/review-worker": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "4.21.0"
  }
}
