{
  "name": "@review-agent/review-cli",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/index.d.ts",
    "dist/index.js",
    "dist/service-client.d.ts",
    "dist/service-client.js"
  ],
  "bin": {
    "review-agent": "dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run --passWithNoTests",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@review-agent/review-convex-bridge": "workspace:*",
    "@review-agent/review-core": "workspace:*",
    "@review-agent/review-provider-registry": "workspace:*",
    "@review-agent/review-types": "workspace:*",
    "commander": "14.0.3"
  },
  "devDependencies": {
    "tsx": "4.21.0"
  }
}
