{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "publicationId": {
      "type": "string",
      "minLength": 1
    },
    "reviewId": {
      "type": "string",
      "minLength": 1
    },
    "channel": {
      "type": "string",
      "enum": ["checkRun", "sarif", "pullRequestComment"]
    },
    "targetKey": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["published", "skipped", "unsupported", "failed"]
    },
    "externalId": {
      "type": "string",
      "minLength": 1
    },
    "externalUrl": {
      "type": "string",
      "minLength": 1
    },
    "marker": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "error": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "createdAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "updatedAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "required": [
    "publicationId",
    "reviewId",
    "channel",
    "targetKey",
    "status",
    "createdAt",
    "updatedAt"
  ],
  "additionalProperties": false
}
