{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "reviewId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed", "cancelled"]
    },
    "detachedRunId": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "object",
      "properties": {
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "minLength": 1
              },
              "body": {
                "type": "string",
                "minLength": 1
              },
              "priority": {
                "anyOf": [
                  {
                    "type": "number",
                    "const": 0
                  },
                  {
                    "type": "number",
                    "const": 1
                  },
                  {
                    "type": "number",
                    "const": 2
                  },
                  {
                    "type": "number",
                    "const": 3
                  }
                ]
              },
              "confidenceScore": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "codeLocation": {
                "type": "object",
                "properties": {
                  "absoluteFilePath": {
                    "type": "string",
                    "minLength": 1
                  },
                  "lineRange": {
                    "type": "object",
                    "properties": {
                      "start": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "end": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      }
                    },
                    "required": ["start", "end"],
                    "additionalProperties": false
                  }
                },
                "required": ["absoluteFilePath", "lineRange"],
                "additionalProperties": false
              },
              "fingerprint": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "title",
              "body",
              "confidenceScore",
              "codeLocation",
              "fingerprint"
            ],
            "additionalProperties": false
          }
        },
        "overallCorrectness": {
          "type": "string",
          "enum": ["patch is correct", "patch is incorrect", "unknown"]
        },
        "overallExplanation": {
          "type": "string"
        },
        "overallConfidenceScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "metadata": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "enum": ["codexDelegate", "openaiCompatible"]
            },
            "modelResolved": {
              "type": "string",
              "minLength": 1
            },
            "executionMode": {
              "type": "string",
              "enum": ["localTrusted", "remoteSandbox"]
            },
            "promptPack": {
              "type": "string",
              "minLength": 1
            },
            "gitContext": {
              "type": "object",
              "properties": {
                "mode": {
                  "type": "string",
                  "minLength": 1
                },
                "baseRef": {
                  "type": "string",
                  "minLength": 1
                },
                "mergeBaseSha": {
                  "type": "string",
                  "minLength": 1
                },
                "commitSha": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": ["mode"],
              "additionalProperties": false
            },
            "sandboxId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+-]*$"
            },
            "providerTelemetry": {
              "type": "object",
              "properties": {
                "policyVersion": {
                  "type": "string",
                  "minLength": 1
                },
                "requestedModel": {
                  "type": "string",
                  "minLength": 1
                },
                "resolvedModel": {
                  "type": "string",
                  "minLength": 1
                },
                "route": {
                  "type": "string",
                  "minLength": 1
                },
                "finalProvider": {
                  "type": "string",
                  "minLength": 1
                },
                "fallbackOrder": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "fallbackUsed": {
                  "type": "boolean"
                },
                "maxInputChars": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "maxOutputTokens": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "timeoutMs": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "maxAttempts": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "retention": {
                  "type": "string",
                  "enum": [
                    "zdrEnforced",
                    "providerRetained",
                    "unknown",
                    "byokUnverified"
                  ]
                },
                "zdrRequired": {
                  "type": "boolean"
                },
                "disallowPromptTraining": {
                  "type": "boolean"
                },
                "failureClass": {
                  "type": "string",
                  "enum": [
                    "none",
                    "policy",
                    "budget",
                    "auth",
                    "rate_limit",
                    "timeout",
                    "provider_unavailable",
                    "invalid_response",
                    "cancelled",
                    "unknown"
                  ]
                },
                "totalLatencyMs": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "attempts": {
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "route": {
                        "type": "string",
                        "minLength": 1
                      },
                      "model": {
                        "type": "string",
                        "minLength": 1
                      },
                      "provider": {
                        "type": "string",
                        "minLength": 1
                      },
                      "status": {
                        "type": "string",
                        "enum": ["success", "failed", "skipped"]
                      },
                      "latencyMs": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 9007199254740991
                      },
                      "failureClass": {
                        "type": "string",
                        "enum": [
                          "none",
                          "policy",
                          "budget",
                          "auth",
                          "rate_limit",
                          "timeout",
                          "provider_unavailable",
                          "invalid_response",
                          "cancelled",
                          "unknown"
                        ]
                      },
                      "errorCode": {
                        "type": "string",
                        "minLength": 1
                      },
                      "retryable": {
                        "type": "boolean"
                      },
                      "generationId": {
                        "type": "string",
                        "minLength": 1
                      },
                      "usage": {
                        "type": "object",
                        "properties": {
                          "status": {
                            "type": "string",
                            "enum": ["reported", "unknown"]
                          },
                          "inputTokens": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 9007199254740991
                          },
                          "outputTokens": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 9007199254740991
                          },
                          "totalTokens": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 9007199254740991
                          },
                          "reasoningTokens": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 9007199254740991
                          },
                          "cachedInputTokens": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 9007199254740991
                          },
                          "costUsd": {
                            "type": "number",
                            "minimum": 0
                          },
                          "marketCostUsd": {
                            "type": "number",
                            "minimum": 0
                          }
                        },
                        "required": ["status"],
                        "additionalProperties": false
                      }
                    },
                    "required": ["route", "model", "status", "latencyMs"],
                    "additionalProperties": false
                  }
                },
                "usage": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["reported", "unknown"]
                    },
                    "inputTokens": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    "outputTokens": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    "totalTokens": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    "reasoningTokens": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    "cachedInputTokens": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    "costUsd": {
                      "type": "number",
                      "minimum": 0
                    },
                    "marketCostUsd": {
                      "type": "number",
                      "minimum": 0
                    }
                  },
                  "required": ["status"],
                  "additionalProperties": false
                }
              },
              "required": [
                "policyVersion",
                "resolvedModel",
                "route",
                "fallbackOrder",
                "fallbackUsed",
                "maxInputChars",
                "maxOutputTokens",
                "timeoutMs",
                "maxAttempts",
                "retention",
                "zdrRequired",
                "disallowPromptTraining",
                "failureClass",
                "totalLatencyMs",
                "attempts",
                "usage"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "provider",
            "modelResolved",
            "executionMode",
            "promptPack",
            "gitContext"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "findings",
        "overallCorrectness",
        "overallExplanation",
        "overallConfidenceScore",
        "metadata"
      ],
      "additionalProperties": false
    }
  },
  "required": ["reviewId", "status"],
  "additionalProperties": false
}
