{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "reviewId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed", "cancelled"]
    },
    "error": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "object",
      "properties": {
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "minLength": 1
              },
              "body": {
                "type": "string",
                "minLength": 1
              },
              "priority": {
                "anyOf": [
                  {
                    "type": "number",
                    "const": 0
                  },
                  {
                    "type": "number",
                    "const": 1
                  },
                  {
                    "type": "number",
                    "const": 2
                  },
                  {
                    "type": "number",
                    "const": 3
                  }
                ]
              },
              "confidenceScore": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "codeLocation": {
                "type": "object",
                "properties": {
                  "absoluteFilePath": {
                    "type": "string",
                    "minLength": 1
                  },
                  "lineRange": {
                    "type": "object",
                    "properties": {
                      "start": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "end": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      }
                    },
                    "required": ["start", "end"],
                    "additionalProperties": false
                  }
                },
                "required": ["absoluteFilePath", "lineRange"],
                "additionalProperties": false
              },
              "fingerprint": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "title",
              "body",
              "confidenceScore",
              "codeLocation",
              "fingerprint"
            ],
            "additionalProperties": false
          }
        },
        "overallCorrectness": {
          "type": "string",
          "enum": ["patch is correct", "patch is incorrect", "unknown"]
        },
        "overallExplanation": {
          "type": "string"
        },
        "overallConfidenceScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "metadata": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "enum": ["codexDelegate", "openaiCompatible"]
            },
            "modelResolved": {
              "type": "string",
              "minLength": 1
            },
            "executionMode": {
              "type": "string",
              "enum": ["localTrusted", "remoteSandbox"]
            },
            "promptPack": {
              "type": "string",
              "minLength": 1
            },
            "gitContext": {
              "type": "object",
              "properties": {
                "mode": {
                  "type": "string",
                  "minLength": 1
                },
                "baseRef": {
                  "type": "string",
                  "minLength": 1
                },
                "mergeBaseSha": {
                  "type": "string",
                  "minLength": 1
                },
                "commitSha": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": ["mode"],
              "additionalProperties": false
            }
          },
          "required": [
            "provider",
            "modelResolved",
            "executionMode",
            "promptPack",
            "gitContext"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "findings",
        "overallCorrectness",
        "overallExplanation",
        "overallConfidenceScore",
        "metadata"
      ],
      "additionalProperties": false
    },
    "createdAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "updatedAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "required": ["reviewId", "status", "createdAt", "updatedAt"],
  "additionalProperties": false
}
