{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "reviewId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed", "cancelled"]
    },
    "error": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "object",
      "properties": {
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "minLength": 1
              },
              "body": {
                "type": "string",
                "minLength": 1
              },
              "priority": {
                "anyOf": [
                  {
                    "type": "number",
                    "const": 0
                  },
                  {
                    "type": "number",
                    "const": 1
                  },
                  {
                    "type": "number",
                    "const": 2
                  },
                  {
                    "type": "number",
                    "const": 3
                  }
                ]
              },
              "confidenceScore": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "codeLocation": {
                "type": "object",
                "properties": {
                  "absoluteFilePath": {
                    "type": "string",
                    "minLength": 1
                  },
                  "lineRange": {
                    "type": "object",
                    "properties": {
                      "start": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "end": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      }
                    },
                    "required": ["start", "end"],
                    "additionalProperties": false
                  }
                },
                "required": ["absoluteFilePath", "lineRange"],
                "additionalProperties": false
              },
              "fingerprint": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "title",
              "body",
              "confidenceScore",
              "codeLocation",
              "fingerprint"
            ],
            "additionalProperties": false
          }
        },
        "overallCorrectness": {
          "type": "string",
          "enum": ["patch is correct", "patch is incorrect", "unknown"]
        },
        "overallExplanation": {
          "type": "string"
        },
        "overallConfidenceScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "metadata": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "enum": ["codexDelegate", "openaiCompatible"]
            },
            "modelResolved": {
              "type": "string",
              "minLength": 1
            },
            "executionMode": {
              "type": "string",
              "enum": ["localTrusted", "remoteSandbox"]
            },
            "promptPack": {
              "type": "string",
              "minLength": 1
            },
            "gitContext": {
              "type": "object",
              "properties": {
                "mode": {
                  "type": "string",
                  "minLength": 1
                },
                "baseRef": {
                  "type": "string",
                  "minLength": 1
                },
                "mergeBaseSha": {
                  "type": "string",
                  "minLength": 1
                },
                "commitSha": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": ["mode"],
              "additionalProperties": false
            },
            "sandboxId": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "provider",
            "modelResolved",
            "executionMode",
            "promptPack",
            "gitContext"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "findings",
        "overallCorrectness",
        "overallExplanation",
        "overallConfidenceScore",
        "metadata"
      ],
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "properties": {
        "reviewId": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["queued", "running", "completed", "failed", "cancelled"]
        },
        "request": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "enum": ["codexDelegate", "openaiCompatible"]
            },
            "executionMode": {
              "type": "string",
              "enum": ["localTrusted", "remoteSandbox"]
            },
            "targetType": {
              "type": "string",
              "enum": ["uncommittedChanges", "baseBranch", "commit", "custom"]
            },
            "outputFormats": {
              "minItems": 1,
              "maxItems": 3,
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["sarif", "json", "markdown"]
              }
            },
            "model": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            }
          },
          "required": [
            "provider",
            "executionMode",
            "targetType",
            "outputFormats"
          ],
          "additionalProperties": false
        },
        "repository": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "const": "github"
            },
            "owner": {
              "type": "string",
              "minLength": 1,
              "maxLength": 39,
              "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
            },
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100,
              "pattern": "^(?!.*\\.git$)[A-Za-z0-9._-]+$"
            },
            "fullName": {
              "type": "string",
              "minLength": 1,
              "maxLength": 140
            },
            "repositoryId": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "installationId": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "visibility": {
              "type": "string",
              "enum": ["public", "private", "internal"]
            },
            "pullRequestNumber": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "ref": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "commitSha": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "pattern": "^[0-9a-fA-F]{7,64}$"
            }
          },
          "required": [
            "provider",
            "owner",
            "name",
            "fullName",
            "repositoryId",
            "installationId",
            "visibility"
          ],
          "additionalProperties": false,
          "not": {
            "anyOf": [
              {
                "required": ["pullRequestNumber", "ref"]
              },
              {
                "required": ["pullRequestNumber", "commitSha"]
              },
              {
                "required": ["ref", "commitSha"]
              }
            ]
          }
        },
        "error": {
          "type": "string",
          "minLength": 1
        },
        "findingCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "artifactFormats": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["sarif", "json", "markdown"]
          }
        },
        "publicationCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "modelResolved": {
          "type": "string",
          "minLength": 1
        },
        "detachedRunId": {
          "type": "string",
          "minLength": 1
        },
        "workflowRunId": {
          "type": "string",
          "minLength": 1
        },
        "sandboxId": {
          "type": "string",
          "minLength": 1
        },
        "cancelRequestedAt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "completedAt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "createdAt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "updatedAt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "reviewId",
        "status",
        "request",
        "findingCount",
        "artifactFormats",
        "publicationCount",
        "createdAt",
        "updatedAt"
      ],
      "additionalProperties": false
    },
    "publications": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "publicationId": {
            "type": "string",
            "minLength": 1
          },
          "reviewId": {
            "type": "string",
            "minLength": 1
          },
          "channel": {
            "type": "string",
            "enum": ["checkRun", "sarif", "pullRequestComment"]
          },
          "targetKey": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["published", "skipped", "unsupported", "failed"]
          },
          "externalId": {
            "type": "string",
            "minLength": 1
          },
          "externalUrl": {
            "type": "string",
            "minLength": 1
          },
          "marker": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "error": {
            "type": "string",
            "minLength": 1
          },
          "metadata": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "createdAt": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "updatedAt": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "publicationId",
          "reviewId",
          "channel",
          "targetKey",
          "status",
          "createdAt",
          "updatedAt"
        ],
        "additionalProperties": false
      }
    },
    "triage": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "reviewId": {
            "type": "string",
            "minLength": 1
          },
          "fingerprint": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "accepted",
              "false-positive",
              "fixed",
              "published",
              "dismissed",
              "ignored"
            ]
          },
          "note": {
            "type": "string",
            "maxLength": 4096
          },
          "actor": {
            "type": "string",
            "minLength": 1
          },
          "createdAt": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "updatedAt": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "reviewId",
          "fingerprint",
          "status",
          "createdAt",
          "updatedAt"
        ],
        "additionalProperties": false
      }
    },
    "triageAudit": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "auditId": {
            "type": "string",
            "minLength": 1
          },
          "reviewId": {
            "type": "string",
            "minLength": 1
          },
          "fingerprint": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "fromStatus": {
            "type": "string",
            "enum": [
              "open",
              "accepted",
              "false-positive",
              "fixed",
              "published",
              "dismissed",
              "ignored"
            ]
          },
          "toStatus": {
            "type": "string",
            "enum": [
              "open",
              "accepted",
              "false-positive",
              "fixed",
              "published",
              "dismissed",
              "ignored"
            ]
          },
          "note": {
            "type": "string",
            "maxLength": 4096
          },
          "actor": {
            "type": "string",
            "minLength": 1
          },
          "createdAt": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "auditId",
          "reviewId",
          "fingerprint",
          "toStatus",
          "createdAt"
        ],
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "reviewId": {
            "type": "string",
            "minLength": 1
          },
          "format": {
            "type": "string",
            "enum": ["sarif", "json", "markdown"]
          },
          "contentType": {
            "type": "string",
            "minLength": 1
          },
          "byteLength": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "createdAt": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "reviewId",
          "format",
          "contentType",
          "byteLength",
          "createdAt"
        ],
        "additionalProperties": false
      }
    },
    "createdAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "updatedAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "required": ["reviewId", "status", "createdAt", "updatedAt"],
  "additionalProperties": false
}
