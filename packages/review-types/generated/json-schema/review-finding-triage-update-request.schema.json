{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "open",
        "accepted",
        "false-positive",
        "fixed",
        "published",
        "dismissed",
        "ignored"
      ]
    },
    "note": {
      "anyOf": [
        {
          "type": "string",
          "maxLength": 4096
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false
}
