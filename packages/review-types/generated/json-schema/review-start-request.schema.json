{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "properties": {
        "cwd": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "target": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "uncommittedChanges"
                }
              },
              "required": ["type"],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "baseBranch"
                },
                "branch": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256
                }
              },
              "required": ["type", "branch"],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "commit"
                },
                "sha": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "pattern": "^[0-9a-fA-F]{7,64}$"
                },
                "title": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 512
                }
              },
              "required": ["type", "sha"],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "custom"
                },
                "instructions": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 16384
                }
              },
              "required": ["type", "instructions"],
              "additionalProperties": false
            }
          ]
        },
        "provider": {
          "type": "string",
          "enum": ["codexDelegate", "openaiCompatible"]
        },
        "executionMode": {
          "default": "localTrusted",
          "type": "string",
          "enum": ["localTrusted", "remoteSandbox"]
        },
        "model": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "reasoningEffort": {
          "type": "string",
          "enum": ["minimal", "low", "medium", "high", "xhigh"]
        },
        "includePaths": {
          "maxItems": 100,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "excludePaths": {
          "maxItems": 100,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "maxFiles": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 1000
        },
        "maxDiffBytes": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 4194304
        },
        "outputFormats": {
          "minItems": 1,
          "maxItems": 3,
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["sarif", "json", "markdown"]
          }
        },
        "severityThreshold": {
          "type": "string",
          "enum": ["p0", "p1", "p2", "p3"]
        },
        "detached": {
          "type": "boolean"
        }
      },
      "required": ["cwd", "target", "provider", "outputFormats"],
      "additionalProperties": false
    },
    "delivery": {
      "default": "inline",
      "type": "string",
      "enum": ["inline", "detached"]
    },
    "repository": {
      "type": "object",
      "properties": {
        "provider": {
          "default": "github",
          "type": "string",
          "const": "github"
        },
        "owner": {
          "type": "string",
          "minLength": 1,
          "maxLength": 39,
          "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^(?!.*\\.git$)[A-Za-z0-9._-]+$"
        },
        "repositoryId": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "installationId": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "pullRequestNumber": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "commitSha": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^[0-9a-fA-F]{7,64}$"
        }
      },
      "required": ["owner", "name"],
      "additionalProperties": false
    }
  },
  "required": ["request"],
  "additionalProperties": false
}
