{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "reviewId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed", "cancelled"]
    },
    "request": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["codexDelegate", "openaiCompatible"]
        },
        "executionMode": {
          "type": "string",
          "enum": ["localTrusted", "remoteSandbox"]
        },
        "targetType": {
          "type": "string",
          "enum": ["uncommittedChanges", "baseBranch", "commit", "custom"]
        },
        "outputFormats": {
          "minItems": 1,
          "maxItems": 3,
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["sarif", "json", "markdown"]
          }
        },
        "model": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      },
      "required": ["provider", "executionMode", "targetType", "outputFormats"],
      "additionalProperties": false
    },
    "repository": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "const": "github"
        },
        "owner": {
          "type": "string",
          "minLength": 1,
          "maxLength": 39,
          "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^(?!.*\\.git$)[A-Za-z0-9._-]+$"
        },
        "fullName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 140
        },
        "repositoryId": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "installationId": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "visibility": {
          "type": "string",
          "enum": ["public", "private", "internal"]
        },
        "pullRequestNumber": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "commitSha": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^[0-9a-fA-F]{7,64}$"
        }
      },
      "required": [
        "provider",
        "owner",
        "name",
        "fullName",
        "repositoryId",
        "installationId",
        "visibility"
      ],
      "additionalProperties": false,
      "not": {
        "anyOf": [
          {
            "required": ["pullRequestNumber", "ref"]
          },
          {
            "required": ["pullRequestNumber", "commitSha"]
          },
          {
            "required": ["ref", "commitSha"]
          }
        ]
      }
    },
    "error": {
      "type": "string",
      "minLength": 1
    },
    "findingCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "artifactFormats": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["sarif", "json", "markdown"]
      }
    },
    "publicationCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "modelResolved": {
      "type": "string",
      "minLength": 1
    },
    "detachedRunId": {
      "type": "string",
      "minLength": 1
    },
    "workflowRunId": {
      "type": "string",
      "minLength": 1
    },
    "sandboxId": {
      "type": "string",
      "minLength": 1
    },
    "cancelRequestedAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "completedAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "createdAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "updatedAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "required": [
    "reviewId",
    "status",
    "request",
    "findingCount",
    "artifactFormats",
    "publicationCount",
    "createdAt",
    "updatedAt"
  ],
  "additionalProperties": false
}
