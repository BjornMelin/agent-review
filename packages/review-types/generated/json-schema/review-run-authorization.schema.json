{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "principal": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "githubUser"
            },
            "githubUserId": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "login": {
              "type": "string",
              "minLength": 1,
              "maxLength": 39,
              "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
            }
          },
          "required": ["type", "githubUserId", "login"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "serviceToken"
            },
            "tokenId": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            "tokenPrefix": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            },
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            }
          },
          "required": ["type", "tokenId", "tokenPrefix"],
          "additionalProperties": false
        }
      ]
    },
    "repository": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "const": "github"
        },
        "repositoryId": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "installationId": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "owner": {
          "type": "string",
          "minLength": 1,
          "maxLength": 39,
          "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^(?!.*\\.git$)[A-Za-z0-9._-]+$"
        },
        "fullName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 140
        },
        "visibility": {
          "type": "string",
          "enum": ["public", "private", "internal"]
        },
        "permissions": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string",
            "enum": ["read", "write", "admin"]
          }
        },
        "pullRequestNumber": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "commitSha": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^[0-9a-fA-F]{7,64}$"
        }
      },
      "required": [
        "provider",
        "repositoryId",
        "installationId",
        "owner",
        "name",
        "fullName",
        "visibility",
        "permissions"
      ],
      "additionalProperties": false,
      "not": {
        "anyOf": [
          {
            "required": ["pullRequestNumber", "ref"]
          },
          {
            "required": ["pullRequestNumber", "commitSha"]
          },
          {
            "required": ["ref", "commitSha"]
          }
        ]
      }
    },
    "scopes": {
      "minItems": 1,
      "maxItems": 16,
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "review:start",
          "review:read",
          "review:cancel",
          "review:publish",
          "token:admin"
        ]
      },
      "uniqueItems": true
    },
    "actor": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "requestHash": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "authorizedAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "required": [
    "principal",
    "repository",
    "scopes",
    "actor",
    "requestHash",
    "authorizedAt"
  ],
  "additionalProperties": false
}
