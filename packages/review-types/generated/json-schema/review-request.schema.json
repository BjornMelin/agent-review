{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "cwd": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "uncommittedChanges"
            }
          },
          "required": ["type"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "baseBranch"
            },
            "branch": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["type", "branch"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "commit"
            },
            "sha": {
              "type": "string",
              "minLength": 1
            },
            "title": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["type", "sha"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "custom"
            },
            "instructions": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["type", "instructions"],
          "additionalProperties": false
        }
      ]
    },
    "provider": {
      "type": "string",
      "enum": ["codexDelegate", "openaiCompatible"]
    },
    "executionMode": {
      "default": "localTrusted",
      "type": "string",
      "enum": ["localTrusted", "remoteSandbox"]
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "reasoningEffort": {
      "type": "string",
      "enum": ["minimal", "low", "medium", "high", "xhigh"]
    },
    "includePaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "excludePaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "maxFiles": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "maxDiffBytes": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "outputFormats": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["sarif", "json", "markdown"]
      }
    },
    "severityThreshold": {
      "type": "string",
      "enum": ["p0", "p1", "p2", "p3"]
    },
    "detached": {
      "type": "boolean"
    }
  },
  "required": ["cwd", "target", "provider", "outputFormats"],
  "additionalProperties": false
}
