{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "reviewId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed", "cancelled"]
    },
    "request": {
      "type": "object",
      "properties": {
        "cwd": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "target": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "uncommittedChanges"
                }
              },
              "required": ["type"],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "baseBranch"
                },
                "branch": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256
                }
              },
              "required": ["type", "branch"],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "commit"
                },
                "sha": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "pattern": "^[0-9a-fA-F]{7,64}$"
                },
                "title": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 512
                }
              },
              "required": ["type", "sha"],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "custom"
                },
                "instructions": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 16384
                }
              },
              "required": ["type", "instructions"],
              "additionalProperties": false
            }
          ]
        },
        "provider": {
          "type": "string",
          "enum": ["codexDelegate", "openaiCompatible"]
        },
        "executionMode": {
          "default": "localTrusted",
          "type": "string",
          "enum": ["localTrusted", "remoteSandbox"]
        },
        "model": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "reasoningEffort": {
          "type": "string",
          "enum": ["minimal", "low", "medium", "high", "xhigh"]
        },
        "includePaths": {
          "maxItems": 100,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "excludePaths": {
          "maxItems": 100,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "maxFiles": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 1000
        },
        "maxDiffBytes": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 4194304
        },
        "outputFormats": {
          "minItems": 1,
          "maxItems": 3,
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["sarif", "json", "markdown"]
          }
        },
        "severityThreshold": {
          "type": "string",
          "enum": ["p0", "p1", "p2", "p3"]
        },
        "detached": {
          "type": "boolean"
        }
      },
      "required": ["cwd", "target", "provider", "outputFormats"],
      "additionalProperties": false
    },
    "authorization": {
      "type": "object",
      "properties": {
        "principal": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "githubUser"
                },
                "githubUserId": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "login": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 39,
                  "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
                }
              },
              "required": ["type", "githubUserId", "login"],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "serviceToken"
                },
                "tokenId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 64
                },
                "tokenPrefix": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 80
                },
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128
                }
              },
              "required": ["type", "tokenId", "tokenPrefix"],
              "additionalProperties": false
            }
          ]
        },
        "repository": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "const": "github"
            },
            "repositoryId": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "installationId": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "owner": {
              "type": "string",
              "minLength": 1,
              "maxLength": 39,
              "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
            },
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100,
              "pattern": "^(?!.*\\.git$)[A-Za-z0-9._-]+$"
            },
            "fullName": {
              "type": "string",
              "minLength": 1,
              "maxLength": 140
            },
            "visibility": {
              "type": "string",
              "enum": ["public", "private", "internal"]
            },
            "permissions": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {
                "type": "string",
                "enum": ["read", "write", "admin"]
              }
            },
            "pullRequestNumber": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "ref": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "commitSha": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "pattern": "^[0-9a-fA-F]{7,64}$"
            }
          },
          "required": [
            "provider",
            "repositoryId",
            "installationId",
            "owner",
            "name",
            "fullName",
            "visibility",
            "permissions"
          ],
          "additionalProperties": false,
          "not": {
            "anyOf": [
              {
                "required": ["pullRequestNumber", "ref"]
              },
              {
                "required": ["pullRequestNumber", "commitSha"]
              },
              {
                "required": ["ref", "commitSha"]
              }
            ]
          }
        },
        "scopes": {
          "minItems": 1,
          "maxItems": 16,
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "review:start",
              "review:read",
              "review:cancel",
              "review:publish",
              "token:admin"
            ]
          },
          "uniqueItems": true
        },
        "actor": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "requestHash": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "authorizedAt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "principal",
        "repository",
        "scopes",
        "actor",
        "requestHash",
        "authorizedAt"
      ],
      "additionalProperties": false
    },
    "createdAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "updatedAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "completedAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "error": {
      "type": "string",
      "minLength": 1
    },
    "detachedRunId": {
      "type": "string",
      "minLength": 1
    },
    "workflowRunId": {
      "type": "string",
      "minLength": 1
    },
    "sandboxId": {
      "type": "string",
      "minLength": 1
    },
    "lease": {
      "type": "object",
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "scopeKey": {
          "type": "string",
          "minLength": 1
        },
        "acquiredAt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "heartbeatAt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "expiresAt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "owner",
        "scopeKey",
        "acquiredAt",
        "heartbeatAt",
        "expiresAt"
      ],
      "additionalProperties": false
    },
    "cancelRequestedAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "required": [
    "reviewId",
    "runId",
    "status",
    "request",
    "createdAt",
    "updatedAt"
  ],
  "additionalProperties": false
}
