{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "reviewId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed", "cancelled"]
    },
    "request": {
      "type": "object",
      "properties": {
        "cwd": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "target": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "uncommittedChanges"
                }
              },
              "required": ["type"],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "baseBranch"
                },
                "branch": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256
                }
              },
              "required": ["type", "branch"],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "commit"
                },
                "sha": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "pattern": "^[0-9a-fA-F]{7,64}$"
                },
                "title": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 512
                }
              },
              "required": ["type", "sha"],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "custom"
                },
                "instructions": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 16384
                }
              },
              "required": ["type", "instructions"],
              "additionalProperties": false
            }
          ]
        },
        "provider": {
          "type": "string",
          "enum": ["codexDelegate", "openaiCompatible"]
        },
        "executionMode": {
          "default": "localTrusted",
          "type": "string",
          "enum": ["localTrusted", "remoteSandbox"]
        },
        "model": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "reasoningEffort": {
          "type": "string",
          "enum": ["minimal", "low", "medium", "high", "xhigh"]
        },
        "includePaths": {
          "maxItems": 100,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "excludePaths": {
          "maxItems": 100,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "maxFiles": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 1000
        },
        "maxDiffBytes": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 4194304
        },
        "outputFormats": {
          "minItems": 1,
          "maxItems": 3,
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["sarif", "json", "markdown"]
          }
        },
        "severityThreshold": {
          "type": "string",
          "enum": ["p0", "p1", "p2", "p3"]
        },
        "detached": {
          "type": "boolean"
        }
      },
      "required": ["cwd", "target", "provider", "outputFormats"],
      "additionalProperties": false
    },
    "authorization": {
      "type": "object",
      "properties": {
        "principal": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "githubUser"
                },
                "githubUserId": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "login": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 39,
                  "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
                }
              },
              "required": ["type", "githubUserId", "login"],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "serviceToken"
                },
                "tokenId": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 64
                },
                "tokenPrefix": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 80
                },
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128
                }
              },
              "required": ["type", "tokenId", "tokenPrefix"],
              "additionalProperties": false
            }
          ]
        },
        "repository": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "const": "github"
            },
            "repositoryId": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "installationId": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "owner": {
              "type": "string",
              "minLength": 1,
              "maxLength": 39,
              "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
            },
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100,
              "pattern": "^(?!.*\\.git$)[A-Za-z0-9._-]+$"
            },
            "fullName": {
              "type": "string",
              "minLength": 1,
              "maxLength": 140
            },
            "visibility": {
              "type": "string",
              "enum": ["public", "private", "internal"]
            },
            "permissions": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {
                "type": "string",
                "enum": ["read", "write", "admin"]
              }
            },
            "pullRequestNumber": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "ref": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            "commitSha": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "pattern": "^[0-9a-fA-F]{7,64}$"
            }
          },
          "required": [
            "provider",
            "repositoryId",
            "installationId",
            "owner",
            "name",
            "fullName",
            "visibility",
            "permissions"
          ],
          "additionalProperties": false,
          "not": {
            "anyOf": [
              {
                "required": ["pullRequestNumber", "ref"]
              },
              {
                "required": ["pullRequestNumber", "commitSha"]
              },
              {
                "required": ["ref", "commitSha"]
              }
            ]
          }
        },
        "scopes": {
          "minItems": 1,
          "maxItems": 16,
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "review:start",
              "review:read",
              "review:cancel",
              "review:publish",
              "token:admin"
            ]
          },
          "uniqueItems": true
        },
        "actor": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "requestHash": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "authorizedAt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "principal",
        "repository",
        "scopes",
        "actor",
        "requestHash",
        "authorizedAt"
      ],
      "additionalProperties": false
    },
    "createdAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "updatedAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "completedAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "error": {
      "type": "string",
      "minLength": 1
    },
    "detachedRunId": {
      "type": "string",
      "minLength": 1
    },
    "workflowRunId": {
      "type": "string",
      "minLength": 1
    },
    "sandboxId": {
      "type": "string",
      "minLength": 1
    },
    "metrics": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["queued", "running", "completed", "failed", "cancelled"]
        },
        "startedAt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "completedAt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "queueMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "provider": {
          "type": "string",
          "enum": ["codexDelegate", "openaiCompatible"]
        },
        "executionMode": {
          "type": "string",
          "enum": ["localTrusted", "remoteSandbox"]
        },
        "targetType": {
          "type": "string",
          "enum": ["uncommittedChanges", "baseBranch", "commit", "custom"]
        },
        "requestedModel": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "resolvedModel": {
          "type": "string",
          "minLength": 1
        },
        "correlation": {
          "type": "object",
          "properties": {
            "reviewId": {
              "type": "string",
              "minLength": 1
            },
            "workflowRunId": {
              "type": "string",
              "minLength": 1
            },
            "sandboxId": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["reviewId"],
          "additionalProperties": false
        },
        "providerSummary": {
          "type": "object",
          "properties": {
            "totalLatencyMs": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "attemptCount": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "fallbackUsed": {
              "type": "boolean"
            },
            "failureClass": {
              "type": "string",
              "enum": [
                "none",
                "policy",
                "budget",
                "auth",
                "rate_limit",
                "timeout",
                "provider_unavailable",
                "invalid_response",
                "cancelled",
                "unknown"
              ]
            },
            "usage": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["reported", "unknown"]
                },
                "inputTokens": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "outputTokens": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "totalTokens": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "reasoningTokens": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "cachedInputTokens": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "costUsd": {
                  "type": "number",
                  "minimum": 0
                },
                "marketCostUsd": {
                  "type": "number",
                  "minimum": 0
                }
              },
              "required": ["status"],
              "additionalProperties": false
            }
          },
          "required": [
            "totalLatencyMs",
            "attemptCount",
            "fallbackUsed",
            "failureClass",
            "usage"
          ],
          "additionalProperties": false
        },
        "sandbox": {
          "type": "object",
          "properties": {
            "commandCount": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "commandDurationMs": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "wallTimeMs": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "outputBytes": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "artifactBytes": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "redactions": {
              "type": "object",
              "properties": {
                "apiKeyLike": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "bearer": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 9007199254740991
                }
              },
              "required": ["apiKeyLike", "bearer"],
              "additionalProperties": false
            }
          },
          "required": [
            "commandCount",
            "commandDurationMs",
            "wallTimeMs",
            "outputBytes",
            "artifactBytes",
            "redactions"
          ],
          "additionalProperties": false
        },
        "artifacts": {
          "type": "object",
          "properties": {
            "count": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "totalBytes": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": ["count", "totalBytes"],
          "additionalProperties": false
        },
        "runtime": {
          "type": "object",
          "properties": {
            "leaseOwner": {
              "type": "string",
              "minLength": 1
            },
            "leaseAcquiredAt": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "leaseHeartbeatAt": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "leaseExpiresAt": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "leaseTtlMs": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "cancelRequestedAt": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "status",
        "startedAt",
        "provider",
        "executionMode",
        "targetType",
        "correlation",
        "artifacts",
        "runtime"
      ],
      "additionalProperties": false
    },
    "lease": {
      "type": "object",
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "scopeKey": {
          "type": "string",
          "minLength": 1
        },
        "acquiredAt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "heartbeatAt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "expiresAt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "owner",
        "scopeKey",
        "acquiredAt",
        "heartbeatAt",
        "expiresAt"
      ],
      "additionalProperties": false
    },
    "cancelRequestedAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "required": [
    "reviewId",
    "runId",
    "status",
    "request",
    "createdAt",
    "updatedAt"
  ],
  "additionalProperties": false
}
