{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "reviewId": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "object",
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1,
          "maxLength": 39,
          "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
        },
        "repo": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^(?!.*\\.git$)[A-Za-z0-9._-]+$"
        },
        "repositoryId": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "installationId": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "commitSha": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^[0-9a-fA-F]{7,64}$"
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "pullRequestNumber": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "pullRequestHeadSha": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^[0-9a-fA-F]{7,64}$"
        }
      },
      "required": [
        "owner",
        "repo",
        "repositoryId",
        "installationId",
        "commitSha"
      ],
      "additionalProperties": false
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "channel": {
            "type": "string",
            "enum": ["checkRun", "sarif", "pullRequestComment"]
          },
          "targetKey": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "enum": [
              "create",
              "update",
              "reuse",
              "delete",
              "skip",
              "unsupported",
              "blocked"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "externalId": {
            "type": "string",
            "minLength": 1
          },
          "externalUrl": {
            "type": "string",
            "minLength": 1
          },
          "marker": {
            "type": "string",
            "minLength": 1
          },
          "fingerprint": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "priority": {
            "anyOf": [
              {
                "type": "number",
                "const": 0
              },
              {
                "type": "number",
                "const": 1
              },
              {
                "type": "number",
                "const": 2
              },
              {
                "type": "number",
                "const": 3
              }
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "bodyPreview": {
            "type": "string",
            "minLength": 1
          },
          "metadata": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "required": ["channel", "targetKey", "action", "message"],
        "additionalProperties": false
      }
    },
    "existingPublications": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "publicationId": {
            "type": "string",
            "minLength": 1
          },
          "reviewId": {
            "type": "string",
            "minLength": 1
          },
          "channel": {
            "type": "string",
            "enum": ["checkRun", "sarif", "pullRequestComment"]
          },
          "targetKey": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["published", "skipped", "unsupported", "failed"]
          },
          "externalId": {
            "type": "string",
            "minLength": 1
          },
          "externalUrl": {
            "type": "string",
            "minLength": 1
          },
          "marker": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "error": {
            "type": "string",
            "minLength": 1
          },
          "metadata": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "createdAt": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "updatedAt": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "publicationId",
          "reviewId",
          "channel",
          "targetKey",
          "status",
          "createdAt",
          "updatedAt"
        ],
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "checkRunAction": {
          "type": "string",
          "enum": [
            "create",
            "update",
            "reuse",
            "delete",
            "skip",
            "unsupported",
            "blocked"
          ]
        },
        "sarifAction": {
          "type": "string",
          "enum": [
            "create",
            "update",
            "reuse",
            "delete",
            "skip",
            "unsupported",
            "blocked"
          ]
        },
        "pullRequestCommentCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "blockedCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": ["pullRequestCommentCount", "blockedCount"],
      "additionalProperties": false
    }
  },
  "required": [
    "reviewId",
    "target",
    "items",
    "existingPublications",
    "summary"
  ],
  "additionalProperties": false
}
