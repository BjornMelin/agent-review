{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "reviewId": {
      "type": "string",
      "minLength": 1
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "format": {
      "type": "string",
      "enum": ["sarif", "json", "markdown"]
    },
    "contentType": {
      "type": "string",
      "minLength": 1
    },
    "byteLength": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "sha256": {
      "type": "string",
      "minLength": 1
    },
    "storageKey": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "required": [
    "reviewId",
    "artifactId",
    "format",
    "contentType",
    "byteLength",
    "sha256",
    "storageKey",
    "createdAt"
  ],
  "additionalProperties": false
}
