{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "channel": {
      "type": "string",
      "enum": ["checkRun", "sarif", "pullRequestComment"]
    },
    "targetKey": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "enum": [
        "create",
        "update",
        "reuse",
        "delete",
        "skip",
        "unsupported",
        "blocked"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "externalId": {
      "type": "string",
      "minLength": 1
    },
    "externalUrl": {
      "type": "string",
      "minLength": 1
    },
    "marker": {
      "type": "string",
      "minLength": 1
    },
    "fingerprint": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "priority": {
      "anyOf": [
        {
          "type": "number",
          "const": 0
        },
        {
          "type": "number",
          "const": 1
        },
        {
          "type": "number",
          "const": 2
        },
        {
          "type": "number",
          "const": 3
        }
      ]
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "line": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "bodyPreview": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": ["channel", "targetKey", "action", "message"],
  "additionalProperties": false
}
