{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "reviewId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed", "cancelled"]
    },
    "cancelled": {
      "type": "boolean"
    }
  },
  "required": ["reviewId", "status"],
  "additionalProperties": false
}
