{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "reviewId": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["queued", "running", "completed", "failed", "cancelled"]
          },
          "request": {
            "type": "object",
            "properties": {
              "provider": {
                "type": "string",
                "enum": ["codexDelegate", "openaiCompatible"]
              },
              "executionMode": {
                "type": "string",
                "enum": ["localTrusted", "remoteSandbox"]
              },
              "targetType": {
                "type": "string",
                "enum": ["uncommittedChanges", "baseBranch", "commit", "custom"]
              },
              "outputFormats": {
                "minItems": 1,
                "maxItems": 3,
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["sarif", "json", "markdown"]
                }
              },
              "model": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256
              }
            },
            "required": [
              "provider",
              "executionMode",
              "targetType",
              "outputFormats"
            ],
            "additionalProperties": false
          },
          "repository": {
            "type": "object",
            "properties": {
              "provider": {
                "type": "string",
                "const": "github"
              },
              "owner": {
                "type": "string",
                "minLength": 1,
                "maxLength": 39,
                "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
              },
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100,
                "pattern": "^(?!.*\\.git$)[A-Za-z0-9._-]+$"
              },
              "fullName": {
                "type": "string",
                "minLength": 1,
                "maxLength": 140
              },
              "repositoryId": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "installationId": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "visibility": {
                "type": "string",
                "enum": ["public", "private", "internal"]
              },
              "pullRequestNumber": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "ref": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256
              },
              "commitSha": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256,
                "pattern": "^[0-9a-fA-F]{7,64}$"
              }
            },
            "required": [
              "provider",
              "owner",
              "name",
              "fullName",
              "repositoryId",
              "installationId",
              "visibility"
            ],
            "additionalProperties": false,
            "not": {
              "anyOf": [
                {
                  "required": ["pullRequestNumber", "ref"]
                },
                {
                  "required": ["pullRequestNumber", "commitSha"]
                },
                {
                  "required": ["ref", "commitSha"]
                }
              ]
            }
          },
          "error": {
            "type": "string",
            "minLength": 1
          },
          "findingCount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "artifactFormats": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["sarif", "json", "markdown"]
            }
          },
          "publicationCount": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "modelResolved": {
            "type": "string",
            "minLength": 1
          },
          "providerTelemetry": {
            "type": "object",
            "properties": {
              "policyVersion": {
                "type": "string",
                "minLength": 1
              },
              "requestedModel": {
                "type": "string",
                "minLength": 1
              },
              "resolvedModel": {
                "type": "string",
                "minLength": 1
              },
              "route": {
                "type": "string",
                "minLength": 1
              },
              "finalProvider": {
                "type": "string",
                "minLength": 1
              },
              "fallbackOrder": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "fallbackUsed": {
                "type": "boolean"
              },
              "maxInputChars": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "maxOutputTokens": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "timeoutMs": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "maxAttempts": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "retention": {
                "type": "string",
                "enum": [
                  "zdrEnforced",
                  "providerRetained",
                  "unknown",
                  "byokUnverified"
                ]
              },
              "zdrRequired": {
                "type": "boolean"
              },
              "disallowPromptTraining": {
                "type": "boolean"
              },
              "failureClass": {
                "type": "string",
                "enum": [
                  "none",
                  "policy",
                  "budget",
                  "auth",
                  "rate_limit",
                  "timeout",
                  "provider_unavailable",
                  "invalid_response",
                  "cancelled",
                  "unknown"
                ]
              },
              "totalLatencyMs": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "attempts": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "route": {
                      "type": "string",
                      "minLength": 1
                    },
                    "model": {
                      "type": "string",
                      "minLength": 1
                    },
                    "provider": {
                      "type": "string",
                      "minLength": 1
                    },
                    "status": {
                      "type": "string",
                      "enum": ["success", "failed", "skipped"]
                    },
                    "latencyMs": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    "failureClass": {
                      "type": "string",
                      "enum": [
                        "none",
                        "policy",
                        "budget",
                        "auth",
                        "rate_limit",
                        "timeout",
                        "provider_unavailable",
                        "invalid_response",
                        "cancelled",
                        "unknown"
                      ]
                    },
                    "errorCode": {
                      "type": "string",
                      "minLength": 1
                    },
                    "retryable": {
                      "type": "boolean"
                    },
                    "generationId": {
                      "type": "string",
                      "minLength": 1
                    },
                    "usage": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string",
                          "enum": ["reported", "unknown"]
                        },
                        "inputTokens": {
                          "type": "integer",
                          "minimum": 0,
                          "maximum": 9007199254740991
                        },
                        "outputTokens": {
                          "type": "integer",
                          "minimum": 0,
                          "maximum": 9007199254740991
                        },
                        "totalTokens": {
                          "type": "integer",
                          "minimum": 0,
                          "maximum": 9007199254740991
                        },
                        "reasoningTokens": {
                          "type": "integer",
                          "minimum": 0,
                          "maximum": 9007199254740991
                        },
                        "cachedInputTokens": {
                          "type": "integer",
                          "minimum": 0,
                          "maximum": 9007199254740991
                        },
                        "costUsd": {
                          "type": "number",
                          "minimum": 0
                        },
                        "marketCostUsd": {
                          "type": "number",
                          "minimum": 0
                        }
                      },
                      "required": ["status"],
                      "additionalProperties": false
                    }
                  },
                  "required": ["route", "model", "status", "latencyMs"],
                  "additionalProperties": false
                }
              },
              "usage": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["reported", "unknown"]
                  },
                  "inputTokens": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "outputTokens": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "totalTokens": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "reasoningTokens": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "cachedInputTokens": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "costUsd": {
                    "type": "number",
                    "minimum": 0
                  },
                  "marketCostUsd": {
                    "type": "number",
                    "minimum": 0
                  }
                },
                "required": ["status"],
                "additionalProperties": false
              }
            },
            "required": [
              "policyVersion",
              "resolvedModel",
              "route",
              "fallbackOrder",
              "fallbackUsed",
              "maxInputChars",
              "maxOutputTokens",
              "timeoutMs",
              "maxAttempts",
              "retention",
              "zdrRequired",
              "disallowPromptTraining",
              "failureClass",
              "totalLatencyMs",
              "attempts",
              "usage"
            ],
            "additionalProperties": false
          },
          "metrics": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "queued",
                  "running",
                  "completed",
                  "failed",
                  "cancelled"
                ]
              },
              "startedAt": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "completedAt": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "durationMs": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "queueMs": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "provider": {
                "type": "string",
                "enum": ["codexDelegate", "openaiCompatible"]
              },
              "executionMode": {
                "type": "string",
                "enum": ["localTrusted", "remoteSandbox"]
              },
              "targetType": {
                "type": "string",
                "enum": ["uncommittedChanges", "baseBranch", "commit", "custom"]
              },
              "requestedModel": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+-]*$"
              },
              "resolvedModel": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+-]*$"
              },
              "correlation": {
                "type": "object",
                "properties": {
                  "reviewId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "workflowRunId": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+-]*$"
                  },
                  "sandboxId": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+-]*$"
                  }
                },
                "required": ["reviewId"],
                "additionalProperties": false
              },
              "providerSummary": {
                "type": "object",
                "properties": {
                  "totalLatencyMs": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "attemptCount": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "fallbackUsed": {
                    "type": "boolean"
                  },
                  "failureClass": {
                    "type": "string",
                    "enum": [
                      "none",
                      "policy",
                      "budget",
                      "auth",
                      "rate_limit",
                      "timeout",
                      "provider_unavailable",
                      "invalid_response",
                      "cancelled",
                      "unknown"
                    ]
                  },
                  "usage": {
                    "type": "object",
                    "properties": {
                      "status": {
                        "type": "string",
                        "enum": ["reported", "unknown"]
                      },
                      "inputTokens": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 9007199254740991
                      },
                      "outputTokens": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 9007199254740991
                      },
                      "totalTokens": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 9007199254740991
                      },
                      "reasoningTokens": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 9007199254740991
                      },
                      "cachedInputTokens": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 9007199254740991
                      },
                      "costUsd": {
                        "type": "number",
                        "minimum": 0
                      },
                      "marketCostUsd": {
                        "type": "number",
                        "minimum": 0
                      }
                    },
                    "required": ["status"],
                    "additionalProperties": false
                  }
                },
                "required": [
                  "totalLatencyMs",
                  "attemptCount",
                  "fallbackUsed",
                  "failureClass",
                  "usage"
                ],
                "additionalProperties": false
              },
              "sandbox": {
                "type": "object",
                "properties": {
                  "commandCount": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "commandDurationMs": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "wallTimeMs": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "outputBytes": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "artifactBytes": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "redactions": {
                    "type": "object",
                    "properties": {
                      "apiKeyLike": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 9007199254740991
                      },
                      "bearer": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 9007199254740991
                      }
                    },
                    "required": ["apiKeyLike", "bearer"],
                    "additionalProperties": false
                  }
                },
                "required": [
                  "commandCount",
                  "commandDurationMs",
                  "wallTimeMs",
                  "outputBytes",
                  "artifactBytes",
                  "redactions"
                ],
                "additionalProperties": false
              },
              "artifacts": {
                "type": "object",
                "properties": {
                  "count": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "totalBytes": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "required": ["count", "totalBytes"],
                "additionalProperties": false
              },
              "runtime": {
                "type": "object",
                "properties": {
                  "leaseOwner": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 256,
                    "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+-]*$"
                  },
                  "leaseAcquiredAt": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "leaseHeartbeatAt": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "leaseExpiresAt": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "leaseTtlMs": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "cancelRequestedAt": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "additionalProperties": false
              }
            },
            "required": [
              "status",
              "startedAt",
              "provider",
              "executionMode",
              "targetType",
              "correlation",
              "artifacts",
              "runtime"
            ],
            "additionalProperties": false
          },
          "detachedRunId": {
            "type": "string",
            "minLength": 1
          },
          "workflowRunId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+-]*$"
          },
          "sandboxId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+-]*$"
          },
          "cancelRequestedAt": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "completedAt": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "createdAt": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "updatedAt": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "reviewId",
          "status",
          "request",
          "findingCount",
          "artifactFormats",
          "publicationCount",
          "createdAt",
          "updatedAt"
        ],
        "additionalProperties": false
      }
    },
    "nextCursor": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["runs"],
  "additionalProperties": false
}
