{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "body": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "anyOf": [
        {
          "type": "number",
          "const": 0
        },
        {
          "type": "number",
          "const": 1
        },
        {
          "type": "number",
          "const": 2
        },
        {
          "type": "number",
          "const": 3
        }
      ]
    },
    "confidenceScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "codeLocation": {
      "type": "object",
      "properties": {
        "absoluteFilePath": {
          "type": "string",
          "minLength": 1
        },
        "lineRange": {
          "type": "object",
          "properties": {
            "start": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "end": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": ["start", "end"],
          "additionalProperties": false
        }
      },
      "required": ["absoluteFilePath", "lineRange"],
      "additionalProperties": false
    },
    "fingerprint": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "title",
    "body",
    "confidenceScore",
    "codeLocation",
    "fingerprint"
  ],
  "additionalProperties": false
}
