{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "route": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["success", "failed", "skipped"]
    },
    "latencyMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "failureClass": {
      "type": "string",
      "enum": [
        "none",
        "policy",
        "budget",
        "auth",
        "rate_limit",
        "timeout",
        "provider_unavailable",
        "invalid_response",
        "cancelled",
        "unknown"
      ]
    },
    "errorCode": {
      "type": "string",
      "minLength": 1
    },
    "retryable": {
      "type": "boolean"
    },
    "generationId": {
      "type": "string",
      "minLength": 1
    },
    "usage": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["reported", "unknown"]
        },
        "inputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "outputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "totalTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "reasoningTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cachedInputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "costUsd": {
          "type": "number",
          "minimum": 0
        },
        "marketCostUsd": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": ["status"],
      "additionalProperties": false
    }
  },
  "required": ["route", "model", "status", "latencyMs"],
  "additionalProperties": false
}
