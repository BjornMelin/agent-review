{
  "name": "@review-agent/review-types",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/index.d.ts",
    "dist/index.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate:schemas": "pnpm run build && node scripts/generate-json-schema.mjs && pnpm exec biome format --write generated/json-schema",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
