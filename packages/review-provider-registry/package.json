{
  "name": "@review-agent/review-provider-registry",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/index.d.ts",
    "dist/index.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@review-agent/review-provider-codex": "workspace:*",
    "@review-agent/review-provider-openai": "workspace:*",
    "@review-agent/review-types": "workspace:*"
  }
}
