{
  "name": "@review-agent/review-git",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run --passWithNoTests",
    "benchmark": "REVIEW_AGENT_RUST_DIFF_BENCH=1 REVIEW_AGENT_STRICT_PERF=1 vitest run src/diff-corpus.test.ts src/performance.test.ts"
  },
  "dependencies": {
    "@review-agent/review-types": "workspace:*"
  }
}
